{
  "name": "@scrimble/api",
  "version": "0.1.0",
  "description": "Scrimble Cloudflare Workers API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .wrangler"
  },
  "dependencies": {
    "@scrimble/shared": "workspace:*",
    "hono": "^4.7.0",
    "jose": "^6.2.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.99.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
